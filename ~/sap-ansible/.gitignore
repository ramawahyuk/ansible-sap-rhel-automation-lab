# ============================================================
# .gitignore — ansible-sap-rhel-automation
# ============================================================

# ── Vault & Secrets ─────────────────────────────────────────
# CRITICAL: Never commit the vault password file
.vault_pass
*.vault_pass
*_vault_pass

# ── Ansible Runtime Files ────────────────────────────────────
ansible.log
*.retry
/tmp/ansible_facts_cache/

# ── Python ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# ── Virtual Environments ─────────────────────────────────────
.venv/
venv/
ENV/

# ── IDE / Editor ─────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ── Collections (installed locally — not tracked) ────────────
# Uncomment if you prefer to track installed collections in git
# (not recommended for large collections like community.sap_install)
collections/ansible_collections/

# ── Temp & Logs ──────────────────────────────────────────────
*.log
*.tmp
*.bak
/tmp/

# ── SSH Keys ─────────────────────────────────────────────────
*.pem
*.key
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
