# ================================================================
# VAULT FILE - SAP Server Credentials
# This file MUST be AES-256 encrypted via Ansible Vault before commit.
#
# Encrypt  : ansible-vault encrypt inventory/group_vars/sap_servers/vault.yml
# Edit     : ansible-vault edit inventory/group_vars/sap_servers/vault.yml
# View     : ansible-vault view inventory/group_vars/sap_servers/vault.yml
#
# WARNING  : This template shows variable NAMES only.
#            Replace placeholder values with real passwords,
#            then encrypt before committing.
# ================================================================

# ── HANA  DB Passwords ──────────────────────────────────────

vault_sap_hana_sys_password: "CHANGE_ME"

# ── SAP Master Password ──────────────────────────────────────
# Sets SAP*, DDIC, and other default user passwords during SWPM
vault_sap_master_password: "CHANGE_ME"

# ── SAP Schema Passwords ─────────────────────────────────────
# SAP database schema user (SAPSR3, SAPHANADB, etc.)
vault_sap_db_schema_password: "CHANGE_ME"

# SAP diagnostics agent password
vault_sap_diagnostics_agent_password: "CHANGE_ME"
